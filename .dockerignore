# ============================================================================
# .dockerignore — Keep build context lean for fast ACR uploads
# ============================================================================

# Git
.git/
.gitignore

# Infrastructure (not needed in container)
infra/
deploy.sh
build.sh
*.bicep
*.bicepparam

# Local data (runtime directories, not repo files)
data/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docs
*.md
LICENSE

# Dashboard (separate deployment)
dashboard/

# OS
.DS_Store
Thumbs.db
